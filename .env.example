NODE_ENV=production
PORT=3000

# MongoDB connection
# Local example: mongodb://127.0.0.1:27017/el_sakka_store
MONGODB_URI=mongodb://127.0.0.1:27017/el_sakka_store
# Optional override for DB name (if omitted, MongoDB uses URI DB name)
MONGODB_DB_NAME=
# Seed MongoDB from legacy server/data/*.json on first run
SEED_FROM_JSON=true

# Owner credentials
OWNER_USERNAME=elsakka
OWNER_PASSWORD=elsakkagroup

# IMPORTANT: change this value in production
OWNER_JWT_SECRET=replace-with-a-long-random-secret
OWNER_TOKEN_TTL=7d

# Google first-time activation (OAuth)
# Redirect URI example for local: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Frontend login page URL to receive callback result
FRONTEND_LOGIN_URL=http://localhost:4200/login

# Comma-separated allowed origins for CORS
# Example: https://elsakka-group.com,https://www.elsakka-group.com
CORS_ORIGINS=

# Runtime storage locations (recommended outside project folder on server)
# Linux example:
# DATA_DIR=/var/www/el-sakka/storage/data
# UPLOADS_DIR=/var/www/el-sakka/storage/uploads
DATA_DIR=
UPLOADS_DIR=

# Frontend serving options from backend
SERVE_FRONTEND=true
# FRONTEND_DIST_DIR=/var/www/el-sakka/app/dist/e-commerce
